$('#js-sendEmailBtn').on('click', function () {
    if ($('#js-SendEmail').valid()) {
        $.ajax({
            type: "POST",
            url: `${Host}/LandingPage/RequestDemo`,
            data: new FormData(document.getElementById('js-SendEmail')),
            processData: false,
            contentType: false,
            success: function (result) {
                if (result) {
                    $('#contactUsModal').modal('hide');
                    $('#messageSentModal').modal('show');
                }
                else {
                    ShowInformationPopupNew(ErrorSendEmail.value, "error");
                }
            },
            error: function (err) {
                console.log(err);
                ShowInformationPopupNew(ErrorSendEmail.value, "error");
            }
        });
    }
    else {
        return;
    }
});

$("#contactUsModal").on("hidden.bs.modal", function () {
    $(this).find('input, textarea').val('');
    $(this).find('span').html('');
});