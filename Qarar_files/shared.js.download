function OpenModal() {
    ShowLoading();
    $.ajax({
        type: 'GET',
        url: `${Host}/SystemSettings/GetDataFromSystemSetting`,
        processData: false,
        dataType: 'html',
        success: function (result) {
            EndLoading();
            if (result != null) {
                $('#LoadModal').html(result);
                $('#headerModal').modal('show')
            }
        },
        error: function () { EndLoading(); }
    })
}
