function ShowInformationPopupNew(msg, type = 'confirmation') {
    $("#js-popupMessage").text(msg);
    $("#InformationPopUpNew").modal("show");

    switch (type) {
        case 'confirmation':
            $("#InformationPopUpTitleNew").html(`&check; ${Confirm.value}`);
            $("#js-popupIcon").attr("src", `${Host}/new version/images/ooui_success.svg`);
            break;
        case 'error':
            $("#InformationPopUpTitleNew").html(`${ErrorPopUP.value} &#33;`);
            $("#js-popupIcon").attr("src", `${Host}/new version/images/lets-icons--close-round-fill.svg`);
            break;
        case 'warning':
            $("#InformationPopUpTitleNew").html(`${Warn.value} &#33;`);
            $("#js-popupIcon").attr("src", `${Host}/new version/images/emojione--warning.svg`);
            break;
        case 'alert':
            $("#InformationPopUpTitleNew").html(`${Alert.value} &#33;`);
            $("#js-popupIcon").attr("src", `${Host}/new version/images/jam--triangle-danger.svg`);
            break;
    }

}


