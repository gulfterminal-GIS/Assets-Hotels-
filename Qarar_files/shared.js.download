function maxValue(id, value) {
    var numbers = document.getElementById(id);
    //console.log(numbers);
    var maxQuantity = value;

    numbers.addEventListener("input", function (e) {
        if (this.value > maxQuantity) {
            this.value = maxQuantity;
        }
    })
};

function base64ToPDF(base64EncodedData, fileName = 'file') {
    const bufferArray = base64ToArrayBuffer(base64EncodedData);
    const blobStore = new Blob([bufferArray], { type: 'application/pdf' });
    if (window.navigator && window.navigator.msSaveOrOpenBlob) {
        window.navigator.msSaveOrOpenBlob(blobStore);
        return;
    }

    const fileURL = URL.createObjectURL(blobStore);
    return fileURL;
}

function base64ToArrayBuffer(base64) {
    var binary_string = window.atob(base64);
    var len = binary_string.length;
    var bytes = new Uint8Array(len);
    for (var i = 0; i < len; i++) {
        bytes[i] = binary_string.charCodeAt(i);
    }
    return bytes.buffer;
}

function CreatePdf(IsScreen, IdentifierNo, UserName, isPrint, htmlString, fileName, selectedElementId, pdfOrientation = "landscape", pdfUnit = 'mm', pdfFormat = 'Ledger') {
    var doc = new DOMParser().parseFromString(htmlString, "text/html");
    var _element = doc.getElementById(selectedElementId);
    /*  var header = doc.getElementById(headerID);*/
    _element.style.position = "relative";
    _element.style.margin = "auto";
    _element.style.padding = 'auto';
    _element.style.height = 'auto';
    _element.style.width = 'auto';
    _element.style.fontFamily = "arial";
    //window.document.body.scrollTop = 0;
    //window.document.documentElement.scrollTop = 0;
    var options = {
        margin: 10,
        autoPaging: 'text',
        filename: fileName,
        image: { type: 'jpeg', quality: 1 },
        html2canvas: { scale: 2, dpi: 300, letterRendering: true },
        jsPDF: { unit: pdfUnit, format: pdfFormat, orientation: pdfOrientation, precision: 32 },
        //pageBreak: { mode: '', before: '.before', after: '.after', avoid: '.avoid' }
        pagebreak: { mode: ['avoid-all', 'css', 'legacy'] }
    }
    var optionsPrintSCreen = {
        margin: 10,
        autoPaging: 'text',
        filename: fileName,
        image: { type: 'jpeg', quality: 1 },
        html2canvas: { scale: 2, dpi: 300, letterRendering: true },
        jsPDF: { unit: pdfUnit, format: pdfFormat, orientation: pdfOrientation, precision: 32 },
        
    }
    if (isPrint && IsScreen) {
        html2pdf().from(_element).set(optionsPrintSCreen).outputPdf().then(function (pdf) {
            var base6 = btoa(pdf);
            GetUrlFromBase64(base6);
        });
    }

    if (isPrint) {
        html2pdf().from(_element).set(options).outputPdf().then(function (pdf) {
            var base6 = btoa(pdf);
            GetUrlFromBase64(base6);
        });
    }
    else {
        html2pdf().from(_element).set(options).toPdf().get('pdf').then(function (pdf) {
            var totalPages = pdf.internal.getNumberOfPages();
            for (i = 1; i <= totalPages; i++) {
                pdf.setPage(i);
                pdf.setFontSize(10);
                pdf.setTextColor(100);
                pdf.text('Page ' + i + ' of ' + totalPages, 20, (pdf.internal.pageSize.getHeight() - 4));

                pdf.text('Report BY: ' + UserName + ' ' + ' ' + IdentifierNo, (pdf.internal.pageSize.getWidth() - 100), (pdf.internal.pageSize.getHeight() - 4));
               
            }

        }).save();
      
    }
}
function CreatePdf2(headerID, IdentifierNo, UserName, isPrint, htmlString, fileName, selectedElementId, pdfOrientation = "landscape", pdfUnit = 'mm', pdfFormat = 'Ledger') {
    var doc = new DOMParser().parseFromString(htmlString, "text/html");
    var _element = doc.getElementById(selectedElementId);
    var header = doc.getElementById(headerID);
    _element.style.position = "relative";
    _element.style.margin = "auto";
    _element.style.padding = 'auto';
    _element.style.height = 'auto';
    _element.style.width = 'auto';
    _element.style.fontFamily = "arial";
   
    var options = {
        margin: 7,
        autoPaging: 'text',
        filename: fileName,
        image: { type: 'jpeg', quality: 1 },
        html2canvas: { scale: 2, dpi: 300, letterRendering: true },
        jsPDF: { unit: pdfUnit, format: pdfFormat, orientation: pdfOrientation, precision: 32 },
       
        pagebreak: { mode: ['avoid-all', 'css', 'legacy'] }
    }

    if (isPrint) {
        html2pdf().from(_element).set(options).outputPdf().then(function (pdf) {
            var base6 = btoa(pdf);
            GetUrlFromBase64(base6);
        });
    }
    else {
        html2pdf().from(_element).set(options).toPdf().get('pdf').then(function (pdf) {
            var totalPages = pdf.internal.getNumberOfPages();
            for (i = 1; i <= totalPages; i++) {
                pdf.setPage(i);
                pdf.setFontSize(10);
                pdf.setTextColor(100);
                pdf.text('Page ' + i + ' of ' + totalPages, 20, (pdf.internal.pageSize.getHeight() - 4));

               
                pdf.text('Report: ' + UserName + ' ' + ' ' + IdentifierNo, (pdf.internal.pageSize.getWidth() - 100), (pdf.internal.pageSize.getHeight() - 4));
               
            }

        }).save();
       
    }
}

function convertArabicNumbersToEnglish(obj) {
    let arabic_numbers = "٠١٢٣٤٥٦٧٨٩".split('');
  
    var arabic_text = $(obj).val();
    let n = '';
    for (let i = 0; i < arabic_text.length; i++) {
        let state = arabic_numbers.indexOf(arabic_text[i]);
        if (state > 0) {
            n += state;
        } else {
            n += arabic_text[i];
        }
    }

    $(obj).val(n);
    return n;
}

//download function onClick
function downloadFile(base64Data, contentType, fileName) {
    const linkSource = `data:${contentType};base64,${base64Data}`;
    /*const linkSource = base64Data;*/
    const downloadLink = document.createElement("a");
    downloadLink.href = linkSource;
    downloadLink.download = fileName;
    downloadLink.click();
    console.log("Success: file downloaded!");
}

